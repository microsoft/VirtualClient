    "Dependencies": [
        {
            "Type": "DependencyPackageInstallation",
            "Parameters": {
                "Scenario": "InstallSystemConfigScriptPackage",
                "BlobContainer": "packages",
                "BlobName": "system_config.1.0.0.zip",
                "PackageName": "system_config",
                "Extract": true
            }
        },
        {
            "Type": "DependencyPackageInstallation",
            "Parameters": {
                "Scenario": "InstallNetworkToolsetPackage",
                "BlobContainer": "packages",
                "BlobName": "networking.3.1.0.zip",
                "PackageName": "networking",
                "Extract": true
            }
        },
        {
            "Type": "LinuxPackageInstallation",
            "Parameters": {
                "Scenario": "InstallLinuxPackages",
                "Packages-Dnf": "iptables"
            }
        },
        {
            "Type": "ExecuteCommand",
            "Parameters": {
                "Scenario": "ConfigureNetwork",
                "Command": "sudo chmod -R 2777 \"{ScriptPackage}\"&&sudo bash -c \"{ScriptPackage}/config_network.sh --disable-firewall=true --enable-busy-poll={EnableBusyPoll}\"",
                "EnableBusyPoll": "$.Parameters.EnableBusyPoll",
                "LogFolderName": "configure_network",
                "ScriptPackage": "{PackageDir/Platform:system_config}",
                "SupportedPlatforms": "linux-x64,linux-arm64"
            }
        },
        {
            "Type": "ExecuteCommand",
            "Parameters": {
                "Scenario": "ConfigureNetwork",
                "Command": "{ScriptPackage}/config_network.cmd",
                "LogFolderName": "configure_network",
                "ScriptPackage": "{PackageDir/Platform:system_config}",
                "SupportedPlatforms": "win-x64,win-arm64"
            }
        },
        {
            "Type": "ApiServer",
            "Parameters": {
                "Scenario": "StartAPIServer"
            }
        }
    ]
